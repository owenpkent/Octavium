# =============================================================================
# Octavium Build Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# EV Code Signing Certificate
# ----------------------------
# Format: 40-character hexadecimal SHA-1 thumbprint (spaces optional, case-insensitive)
#
# How to find your thumbprint:
#
#   Option 1 — PowerShell (with your token plugged in):
#     Get-ChildItem Cert:\CurrentUser\My -CodeSigningCert | Format-List Thumbprint, Subject
#
#   Option 2 — certutil:
#     certutil -user -store My
#     (Look for the "Cert Hash(sha1)" line under your EV certificate)
#
#   Option 3 — GUI:
#     Win+R → certmgr.msc → Personal → Certificates
#     Double-click your cert → Details tab → Thumbprint field
#
# Example (fake):
#   OCTAVIUM_SIGN_THUMBPRINT=A1B2C3D4E5F6A1B2C3D4E5F6A1B2C3D4E5F6A1B2
#
OCTAVIUM_SIGN_THUMBPRINT=

# Timestamp server URL
# ----------------------------
# Use the timestamp server that matches your Certificate Authority (CA).
# This embeds a trusted timestamp so signatures remain valid after the cert expires.
#
# DigiCert:    http://timestamp.digicert.com
# Sectigo:     http://timestamp.sectigo.com
# GlobalSign:  http://timestamp.globalsign.com/?signature=sha2
# Comodo:      http://timestamp.comodoca.com
#
OCTAVIUM_TIMESTAMP_URL=http://timestamp.digicert.com
